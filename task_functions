def lap_discount():
    a=int(input("Whats the price of the laptop?:"))
    if a==50000:
        print("There is no discount, You have to pay:Rs",a)
    elif a>50000 and a<=100000:
        c=(a*10)/100
        print("The discount is 10%, you have to pay Rs:",a-c)
    elif a>100000 and a<=150000:
        c=(a*15)/100
        print("The discount is 15%, you have to pay Rs:",a-c)
    elif a>150000:
        c=(a*20)/100
        print("The discount is 20%, You have to pay Rs:",a-c)
lap_discount()
