#8 Sum of divisors
'''
def sum_of_divisors():
    a=int(input("Enter a number:"))
    divisor=0
    for i in range(1,a+1):
        if a%i==0:
            divisor+=i
    print("The sum of divisors:",divisor)
sum_of_divisors()
