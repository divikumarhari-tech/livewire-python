#5 Spy number
'''
def add(a):
    b=0
    while a>0:
        c=a%10
        b+=c
        a=a//10
    return b
      
def multiply(a):
    b=1
    while a>0:
        c=a%10
        b*=c
        a=a//10
    return b

a=int(input("Enter a number:"))
if add(a)==multiply(a):
    print(a,"is a Spy number")
else:
    print(a,"is not a spy  number")
