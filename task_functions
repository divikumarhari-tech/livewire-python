#4 Armstrong number
'''
def armstrong():
    a=int(input("Enter a number:"))
    count=0
    x=a
    y=a
    while a>0:
        count+=1
        a=a//10
    d=0
    while x>0:
        c=x%10
        d=d+c**count
        x=x//10
    if d==y:
        return "Armstrong number"
    return "Not armstrong"
print(armstrong())
